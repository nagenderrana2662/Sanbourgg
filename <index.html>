            <button class="chip" data-tag="veg">Veg</button>
            <button class="chip" data-tag="chicken">Chicken</button>
            <button class="chip" data-tag="cheese">Cheese</button>
            <button class="chip" data-tag="spicy">Spicy</button>
            <button class="chip" data-tag="protein">Protein</button>
